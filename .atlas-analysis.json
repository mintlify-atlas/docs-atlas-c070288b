  "keyFeatures": [
    "Self-hosted, open-source payment gateway with no third-party intermediaries",
    "Multi-brand management - run multiple isolated merchant stores from one installation",
    "Double-entry ledger bookkeeping for financial integrity and auditing",
    "White-labeling - custom domains, logos, CSS, and email templates per brand",
    "Plugin system - extend with gateway, addon, and theme plugins",
    "REST API with Bearer token authentication and scoped API keys",
    "Webhooks with HMAC-SHA256 signature verification and delivery logs",
    "Mobile & SMS gateway - Android phone pairing for local bank SMS parsing",
    "Role-based access control (RBAC) for secure team collaboration",
    "WooCommerce integration and multi-language SDK support"
  ],
  "publicApiSurface": [
    "POST /api/v1/payments - Initiate payment intent",
    "GET /api/v1/payments/{payment_id} - Retrieve payment details",
    "GET /api/v1/transactions - List transactions",
    "GET /api/v1/transactions/{trx_id} - Retrieve transaction",
    "GET /api/v1/refunds - List refunds",
    "POST /api/v1/refunds - Request refund",
    "GET /api/v1/refunds/{trx_id} - Retrieve refund",
    "GET /api/v1/customers - List customers",
    "POST /api/v1/customers - Create customer",
    "GET /api/v1/customers/{identifier} - Retrieve customer",
    "GET /api/v1/api-keys - List API keys",
    "POST /api/v1/api-keys - Generate API key",
    "DELETE /api/v1/api-keys/{id} - Revoke API key",
    "POST /api/v1/webhooks/tests - Dispatch test webhook",
    "GET /api/v1/webhooks/deliveries - Webhook delivery log",
    "GET /health - System health check",
    "Hook::apply() - Filter hooks",
    "Hook::do() - Action hooks",
    "Event::listen() - Event listeners",
    "Plugin::service() - Access OwnPay services from plugins",
    "Plugin::config() - Read plugin config",
    "Route::group() - Register plugin routes",
    "Menu::add() - Add admin menu items"
  ]
